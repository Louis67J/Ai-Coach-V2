# === Anthropic (Claude API) ===
# Crée ta clé sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === Intervals.icu ===
# Settings → Developer Settings
INTERVALS_API_KEY=xxxxx
# Ton athlete ID (le numéro après le 'i' dans l'URL de ton profil)
INTERVALS_ATHLETE_ID=i000000

# === Discord Bot ===
# https://discord.com/developers/applications → ton bot → Bot → Token
DISCORD_BOT_TOKEN=xxxxx
# L'ID du salon où le bot répond (clic droit sur le salon → Copier l'ID)
# Pour voir l'option "Copier l'ID", active le mode développeur Discord :
# Paramètres utilisateur → Avancés → Mode développeur
DISCORD_CHANNEL_ID=000000000000000000